# Solana RPC endpoint (Helius, QuickNode, or public devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Path to resolver keypair JSON (solana-keygen format)
RESOLVER_KEYPAIR=./resolver-keypair.json

# Settled program ID (default: devnet deployment)
PROGRAM_ID=7rLM8d27AgkbFjQfJJpHzD4A5pMttD7PzMrqDiMNf7AW

# Poll interval for scanning unresolved markets
POLL_INTERVAL=30s

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable dry-run mode (log what would be resolved, don't submit TXs)
DRY_RUN=false

# Prometheus metrics port (0 to disable)
METRICS_PORT=9090
